      "ExecutionResult": {
        "type": "object",
        "properties": {
          "intent_id": {
            "type": "string"
          },
          "execution_mode": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "tx_hash": {
            "type": "string"
          },
          "block_number": {
            "type": "integer"
          },
          "chain": {
            "type": "string"
          },
          "agent_wallet_address": {
            "type": "string"
          },
          "wallet_provider": {
            "type": "string"
          },
          "readback": {
            "type": "object"
          },
          "error": {
            "type": "string"
          },
          "executed_at": {
            "type": "string"
          }
        }
      }
    }
  }
}
